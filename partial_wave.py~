import numpy as np
from particle import Particle
from particle.exceptions import ParticleNotFound
import physics_engine as pe

class PartialWave:
    def __init__(self, name_or_dict, L, M, epsilon, fraction, phase, m1, m2):
        """
        Initializes a partial wave state.
        name_or_dict: String for PDG lookup (e.g., "rho(770)0") OR a dict for custom states.
        L, M: Spin and spin projection.
        epsilon: Reflectivity (+1 or -1).
        fraction: Target visible percentage (0.0 to 1.0).
        phase: Relative phase in radians.
        m1, m2: Masses of the final state decay products (GeV).
        """
        self.L = L
        self.M = M
        self.epsilon = epsilon
        self.fraction = fraction
        self.phase = phase
        self.m1 = m1
        self.m2 = m2

        if isinstance(name_or_dict, str):
            try:
                # Look up the particle in the PDG database
                p = Particle.from_string(name_or_dict)
                # The 'particle' library returns mass and width in MeV. Convert to GeV.
                self.mass = p.mass / 1000.0
                self.width = p.width / 1000.0
                self.name = p.name
            except ParticleNotFound:
                raise ValueError(f"Particle '{name_or_dict}' not found in PDG database.")
        
        elif isinstance(name_or_dict, dict):
            # Custom particle bypass
            self.mass = name_or_dict.get('mass')
            self.width = name_or_dict.get('width')
            self.name = name_or_dict.get('name', 'CustomState')
            if self.mass is None or self.width is None:
                raise ValueError("Custom particle dictionary must contain 'mass' and 'width' in GeV.")
        else:
            raise TypeError("name_or_dict must be a PDG string or a dictionary.")

    def get_shape(self, M_X):
        """
        Returns the unscaled, complex Breit-Wigner vector over the requested mass bins M_X.
        """
        return pe.relativistic_breit_wigner(
            M_X, self.mass, self.width, self.L, self.m1, self.m2
        )
